# Database URL (for production using Turso/libSQL)
# Format: file:local.db for local, or libsql://db-name.turso.io?authToken=your-token for production
DATABASE_URL=file:local.db

# Turso Database (production)
# Get from: turso db show bilvaskning
# Create token: turso db tokens create bilvaskning
TURSO_DATABASE_URL=libsql://bilvaskning-freddiederenzy.aws-us-east-2.turso.io?authToken=YOUR_TOKEN_HERE

# Twilio SMS Configuration
# Get these from https://console.twilio.com

TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Your phone number (for admin notifications)
ADMIN_PHONE_NUMBER=+45XXXXXXXX

# Admin password for /admin page
# Default: bilvask2024 - change for production!
NEXT_PUBLIC_ADMIN_PASSWORD=bilvask2024
